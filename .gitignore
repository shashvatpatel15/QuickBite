# ------------------------------------------------------------------------------
# 4. Node.js & Frontend (Vite / React)
# ------------------------------------------------------------------------------
# Dependencies
node_modules/
/node_modules/
frontend/node_modules/

# Production build output
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
out/
build-dev/

# Logs & Debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next.js/Nuxt.js build caches (just in case they are used)
.next/
.nuxt/
.svelte-kit/
.expo/
.turbo/
.eslintcache

# Frontend Framework specific
.parcel-cache/
.cache/

# ------------------------------------------------------------------------------
# 5. Environment Variables & Secrets (CRITICAL SECURITY)
# ------------------------------------------------------------------------------
# Ignore all .env files recursively in any directory
**/.env
**/.env.*
**/*.env
**/*.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.backup
!**/.env.example
*.env
**/*.local

# Credentials / Private keys
*.pem
*.key
*.pub
*.p12
*.pfx
secrets.json
client_secret*.json

# ------------------------------------------------------------------------------
# 6. Database Dumps & Local Storage (Avoid committing huge local DB dumps)
# ------------------------------------------------------------------------------
*.sql
*.dump
*.rdb
*.db
**/*.sqlite3
**/*.sqlite3-journal

backend/staticfiles/